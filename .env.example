NODE_ENV=development
NODE_OPTIONS=--no-warnings

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ensnode subgraph-compatible endpoint (browser-called, baked at build)
NEXT_PUBLIC_ENSNODE_SUBGRAPH_URL=

RELICS_API_URL=https://api.relics.bid/api/v1
NEXT_PUBLIC_RELICS_API_URL=https://api.relics.bid/api/v1

ENS_METADATA_URL=https://metadata.ethid.org
NEXT_PUBLIC_ENS_METADATA_URL=https://metadata.ethid.org

ENS_METADATA_CACHE_INVALIDATION_TOKEN=
CACHE_INVALIDATION_TOKEN=

NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Full RPC URLs (key/token embedded), e.g. https://<rpc-host>/hbx_rpc_...
# Unset chains fall back to free public endpoints (see src/lib/wagmi.ts).
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_OPTIMISM_RPC_URL=

OPENSEA_API_KEY=
NEXT_PUBLIC_OPENSEA_API_KEY=
NEXT_PUBLIC_OPENSEA_API_URL=https://api.opensea.io

NEXT_PUBLIC_USE_CONDUIT=true
NEXT_PUBLIC_CAN_CLAIM_POAP=true

X_BEARER_TOKEN=
